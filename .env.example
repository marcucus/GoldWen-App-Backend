# ============================================================
# GoldWen Backend — Variables d'environnement Docker Compose
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# PostgreSQL
POSTGRES_DB=goldwen_db
POSTGRES_USER=goldwen
POSTGRES_PASSWORD=change_me_strong_password

# Matching Service
MATCHING_SERVICE_API_KEY=change_me_strong_api_key

# API principale (voir main-api/.env.example pour la liste complète)
JWT_SECRET=change_me_minimum_32_chars_secret
FRONTEND_URL=http://localhost:8081
WEB_URL=http://localhost:3000
